@studentId = 23
@companyId = 9
@jobId = 15
@applicationId = 17

### =====================================================
### STEP 1: LOGIN AS ADMIN (RUN FIRST)
### =====================================================
POST {{baseUrl}}/auth/login?username=admin&password=admin

### Copy response token and paste into @adminToken

### =====================================================
### STEP 2: CREATE STUDENT (SIGNED PROFILE + HASHED PASSWORD)
### =====================================================
POST {{baseUrl}}/students
Authorization: {{adminToken}}
Content-Type: application/json

{
  "name": "Naman",
  "email": "{{studentEmail}}",
  "password": "{{studentPassword}}",
  "branch": "AI",
  "cgpa": 8.7,
  "skills": "Data Science, AI, ML, Python",
  "projects": "Placement Portal",
  "resumeLink": "https://drive.google.com/resume",
  "phone": "9999999999",
  "university": "MIT-WPU",
  "graduationYear": 2027
}

### Expected: created, signature present, integrityStatus CLEAN
### If 409 conflict comes, continue to STEP 3 with same @studentEmail and @studentPassword=dev.
### Copy returned id into @studentId if new record was created.

### =====================================================
### STEP 3: LOGIN AS STUDENT
### =====================================================
POST {{baseUrl}}/auth/login?username={{studentEmail}}&password={{studentPassword}}

### Copy response token and paste into @studentToken

### =====================================================
### STEP 4: STUDENT VIEWS OWN PROFILE
### =====================================================
GET {{baseUrl}}/students/me
Authorization: {{studentToken}}

### Expected: profile + integrityStatus CLEAN

### =====================================================
### STEP 5: STUDENT UPDATES OWN PROFILE (AUTO RE-SIGN)
### =====================================================
PUT {{baseUrl}}/students/me
Authorization: {{studentToken}}
Content-Type: application/json

{
  "cgpa": 8.4,
  "skills": "Java,Spring,SQL",
  "projects": "Placement Portal, ATS",
  "resumeLink": "https://drive.google.com/resume-v2",
  "phone": "9999999999",
  "university": "MIT-WPU",
  "graduationYear": 2027
}

### Expected: updated + integrityStatus CLEAN

### =====================================================
### STEP 6: CREATE COMPANY (ADMIN)
### =====================================================
POST {{baseUrl}}/companies
Authorization: {{adminToken}}
Content-Type: application/json

{
  "name": "{{companyName}}",
  "password": "admin",
  "role": "Data Analyst",
  "packageOffered": 25
}

### Copy returned id into @companyId if new record was created.

### =====================================================
### STEP 7: LOGIN AS COMPANY
### =====================================================
POST {{baseUrl}}/auth/login?username={{companyName}}&password=admin

### Copy response token and paste into @companyToken

### =====================================================
### STEP 8: CREATE JOB (ADMIN OR COMPANY)
### =====================================================
POST {{baseUrl}}/jobs
Authorization: {{adminToken}}
Content-Type: application/json

{
  "title": "Data Analyst",
  "description": "Data Engineer role at Atlassan",
  "company": {
    "id": {{companyId}}
  }
}

### Copy returned id into @jobId

### =====================================================
### STEP 9: STUDENT APPLIES TO JOB
### =====================================================
POST {{baseUrl}}/applications
Authorization: {{studentToken}}
Content-Type: application/json

{
  "job": {
    "id": {{jobId}}
  }
}

### Expected: application created with signedPayload + signature
### Copy returned id into @applicationId

### =====================================================
### STEP 10: COMPANY VIEWS ITS APPLICATIONS + VALIDITY
### =====================================================
GET {{baseUrl}}/applications/company
Authorization: {{companyToken}}

### Expected: each row has VALID DATA / TAMPERED DATA marker

### =====================================================
### STEP 11: VERIFY A SPECIFIC APPLICATION SIGNATURE
### =====================================================
GET {{baseUrl}}/applications/{{applicationId}}/verify
Authorization: {{companyToken}}

### Expected: VALID DATA

### =====================================================
### STEP 12: COMPANY SHORTLISTS AN APPLICATION
### =====================================================
PUT {{baseUrl}}/applications/{{applicationId}}/status?status=SHORTLISTED
Authorization: {{companyToken}}

### Expected: status updated

### =====================================================
### STEP 13: LOGIN AS PLACEMENT
### =====================================================
POST {{baseUrl}}/auth/login?username=placement1&password=admin

### Copy response token and paste into @placementToken

### =====================================================
### STEP 14: PLACEMENT VIEWS ALL APPLICATIONS
### =====================================================
GET {{baseUrl}}/applications/placement
Authorization: {{placementToken}}

### =====================================================
### STEP 15: VIEW AUDIT LOGS (ADMIN OR PLACEMENT)
### =====================================================
GET {{baseUrl}}/audit
Authorization: {{adminToken}}

### =====================================================
### STEP 16: RUN TPA AUDIT (ADMIN ONLY)
### =====================================================
GET {{baseUrl}}/tpa/audit
Authorization: {{adminToken}}

### Expected: list like 'Application ID X -> VALID' or 'TAMPERED'

### =====================================================
### STEP 17: ANALYTICS (COMPANY)
### =====================================================
GET {{baseUrl}}/applications/analytics/top?jobId={{jobId}}
Authorization: {{companyToken}}

### Average score
GET {{baseUrl}}/applications/analytics/average/{{jobId}}
Authorization: {{companyToken}}

### Selection ratio
GET {{baseUrl}}/applications/analytics/selection-ratio/{{jobId}}
Authorization: {{companyToken}}

### Status distribution
GET {{baseUrl}}/applications/analytics/status/{{jobId}}
Authorization: {{companyToken}}

### =====================================================
### STEP 18: NEGATIVE TEST - WRONG PASSWORD
### =====================================================
POST {{baseUrl}}/auth/login?username={{studentEmail}}&password=wrong

### Expected: 401 Unauthorized

### =====================================================
### STEP 19: NEGATIVE TEST - NO TOKEN
### =====================================================
GET {{baseUrl}}/students

### Expected: 403/401

### =====================================================
### STEP 20: NEGATIVE TEST - STUDENT CANNOT LIST ALL STUDENTS
### =====================================================
GET {{baseUrl}}/students
Authorization: {{studentToken}}

### Expected: 403 Forbidden

### =====================================================
### STEP 21: CANONICAL TAMPER DEMO (MANUAL DB STEP)
### =====================================================
### Run this in MySQL manually:
###   USE placement_portal;
###   UPDATE student SET cgpa = 10.0 WHERE id = {{studentId}};
###   COMMIT;
### Then verify via API:
GET {{baseUrl}}/students/me
Authorization: {{studentToken}}

### Expected: integrityStatus becomes TAMPERED

### Re-sign profile (owner action):
POST {{baseUrl}}/students/me/resign
Authorization: {{studentToken}}

### Verify clean again:
GET {{baseUrl}}/students/me
Authorization: {{studentToken}}

### Expected: integrityStatus back to CLEAN

### =====================================================
### STEP 22: JWT PERSISTENCE ACROSS RESTART
### =====================================================
### 1) Keep current student token from Step 3
### 2) Restart app
### 3) Re-run request below with SAME token
GET {{baseUrl}}/students/me
Authorization: {{studentToken}}

### Expected: still works (keys are persisted)
